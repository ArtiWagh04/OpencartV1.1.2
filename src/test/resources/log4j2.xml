<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

<Properties>
        <Property name="LOG_PATTERN">./logs</Property>
    
    </Properties>


    <Appenders>

        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </Console>

        <!-- File Appender -->
        <File name="FileLogger" fileName="logs/automation.log" append="true">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{1} - %msg%n"/>
        </File>

    </Appenders>

    <Loggers>

        <!-- Root Logger -->
        <Root level="debug">
            <AppenderRef ref="Console"/>
          <AppenderRef ref="FileLogger"/>
        </Root>

    </Loggers>

</Configuration>
